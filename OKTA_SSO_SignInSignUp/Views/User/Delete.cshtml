@model OKTA_SSO_SignInSignUp.Models.User
@{
    ViewBag.Title = "Delete User";
}

<div class="container mt-4">
    <h3 class="mb-3 text-danger">Delete User</h3>
    <div class="card">
        <div class="card-body">
            <p>Are you sure you want to delete this user?</p>
            <dl class="row">
                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@($"{Model.FirstName} {Model.LastName}".Trim())</dd>

                <dt class="col-sm-3">Username</dt>
                <dd class="col-sm-9">@Model.Username</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>

                <dt class="col-sm-3">Role</dt>
                <dd class="col-sm-9">@Model.Role</dd>
            </dl>

            @using (Html.BeginForm("Delete", "User", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.Id)
                <button type="submit" class="btn btn-danger">Yes, delete</button>
                @Html.ActionLink("Cancel", "Index", "User", null, new { @class = "btn btn-link" })
            }
        </div>
    </div>
</div>
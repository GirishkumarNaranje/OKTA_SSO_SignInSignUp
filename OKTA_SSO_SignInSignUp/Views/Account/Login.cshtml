@{
    ViewBag.Title = "Login";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
}

<link href="~/Content/SIte/Site.css" rel="stylesheet" />

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-12 col-md-10 col-lg-9">

        <!-- Main heading -->
        <div class="text-center mb-4">
            <h3>Sign in to your account</h3>
            <p class="text-muted">Choose your preferred sign-in method</p>
        </div>

        <div class="row">
            <!-- LEFT: OKTA SSO -->
            <div class="col-md-5">
                <div class="card auth-card shadow-sm mb-4">
                    <div class="card-header text-center register-header">
                        <h5 class="mb-0">
                            <i class="fas fa-cloud"></i> Sign in with Okta
                        </h5>
                        <small>Recommended for organization users</small>
                    </div>
                    <div class="card-body text-center py-5">
                        <p class="text-muted mb-4">
                            Use your corporate Okta account for secure single sign-on
                        </p>
                        @* Pass returnUrl to OktaLogin action *@
                        <a href="@Url.Action("OktaLogin", "Account", new { returnUrl = ViewBag.ReturnUrl })"
                           class="btn btn-primary btn-lg btn-block">
                            <i class="fas fa-sign-in-alt"></i> Continue with Okta
                        </a>
                    </div>
                </div>
            </div>

            <!-- CENTER: OR DIVIDER -->
            <div class="col-md-2 d-flex align-items-center justify-content-center">
                <div class="text-center">
                    <h4 class="text-muted">OR</h4>
                </div>
            </div>

            <!-- RIGHT: FORMS AUTH -->
            <div class="col-md-5">
                <div class="card register-card shadow-lg">
                    <div class="card-header text-center register-header">
                        <h5 class="mb-0">
                            <i class="fas fa-user"></i> Sign in with Username
                        </h5>
                        <small>Use your local account</small>
                    </div>

                    <div class="card auth-card shadow-sm">
                        <div class="card-body px-4 py-4">

                            @using (Html.BeginForm("Login", "Account", FormMethod.Post, new { @class = "needs-validation", novalidate = "novalidate" }))
                            {
                                @Html.AntiForgeryToken()
                                @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                                @* Hidden field for returnUrl - MUST be inside the form *@
                                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                                <!-- Username -->
                                <div class="form-group">
                                    <label>Username</label>
                                    <input type="text"
                                           class="form-control w-100"
                                           name="username"
                                           placeholder="Enter your username..."
                                           autocomplete="username"
                                           required />
                                    @Html.ValidationMessage("username", "", new { @class = "text-danger" })
                                </div>

                                <!-- Password -->
                                <div class="form-group">
                                    <label class="font-weight-600">Password</label>
                                    <div class="input-group">
                                        <input type="password"
                                               class="form-control w-100"
                                               id="LoginPassword"
                                               name="password"
                                               placeholder="Enter your password..."
                                               autocomplete="current-password"
                                               required />
                                        <div class="input-group-append">
                                            <button class="btn btn-outline-secondary toggle-password"
                                                    type="button"
                                                    aria-label="Show password"
                                                    data-target="#LoginPassword">
                                                Show
                                            </button>
                                        </div>
                                    </div>
                                    @Html.ValidationMessage("password", "", new { @class = "text-danger" })
                                </div>

                                <!-- Remember + Forgot -->
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="rememberMe" id="rememberMe" />
                                        <label class="form-check-label" for="rememberMe">Remember me</label>
                                    </div>
                                    <div>
                                        <a href="#" class="small">Forgot password?</a>
                                    </div>
                                </div>

                                <!-- Submit Button -->
                                <button type="submit" class="btn btn-primary btn-block auth-submit">
                                    Sign in
                                </button>
                            }

                            <!-- Error message -->
                            @if (!string.IsNullOrEmpty(ViewBag.Message as string))
                            {
                                <div class="alert alert-danger text-center mt-3 mb-0">
                                    @ViewBag.Message
                                </div>
                            }
                        </div>
                    </div>

                    <div class="card-footer text-center">
                        <small class="text-muted">
                            New here?
                            @Html.ActionLink("Create an account", "Register", "Account")
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.toggle-password');
            if (!btn) return;
            e.preventDefault();

            var input = document.querySelector(btn.getAttribute('data-target'));
            if (!input) return;

            var isPassword = input.type === 'password';
            input.type = isPassword ? 'text' : 'password';
            btn.textContent = isPassword ? 'Hide' : 'Show';
            btn.setAttribute('aria-label', isPassword ? 'Hide password' : 'Show password');
        });
    })();
</script>
@model OKTA_SSO_SignInSignUp.Models.User
@{
    ViewBag.Title = "Register";
}

<link href="~/Content/SIte/Site.css" rel="stylesheet" />

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-12 col-md-7 col-lg-5">
        <div class="card register-card shadow-lg">

            <!-- HEADER -->
            <div class="card-header text-center register-header">
                <h4 class="mb-0">Create your account</h4>
                <small>Join and start</small>
            </div>

            <!-- The card wrapper should have .auth-card for the CSS to apply -->
            <div class="card auth-card shadow-sm">

                <div class="card-body px-4 py-4">
                    @using (Html.BeginForm("Register", "Account", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                        <!-- First + Last Name -->
                        <div>
                            <div class="form-group ">
                                <label>First name</label>
                                <input class="form-control" name="FirstName" placeholder="John" required />
                            </div>
                            <div class="form-group ">
                                <label>Last name</label>
                                <input class="form-control" name="LastName" placeholder="Doe" required />
                            </div>
                        </div>

                        <!-- Username -->
                        <div class="form-group">
                            <label>Username</label>
                            <input class="form-control" name="Username" placeholder="john.doe" required />
                            <small class="text-muted">This will be your public ID</small>
                        </div>

                        <!-- Email -->
                        <div class="form-group">
                            <label>Email address</label>
                            <input type="email" class="form-control" name="Email" placeholder="you@example.com" />
                        </div>

                        <div class="form-group">
                            <label>Password</label>
                            <div class="input-group">
                                <input type="password" class="form-control" id="Password" name="Password" placeholder="**********" required />
                                <div class="input-group-append">
                                    <button class="btn btn-outline-secondary toggle-password"
                                            type="button"
                                            aria-label="Show password"
                                            data-target="#Password">
                                        Show
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Confirm Password -->
                        <div class="form-group">
                            <label>Confirm password</label>
                            <input type="password" class="form-control" name="ConfirmPassword" placeholder="Re-enter password" required />
                        </div>

                        <!-- CTA -->
                        <button type="submit" class="btn btn-primary btn-block btn-lg mt-3 auth-submit">
                            Create Account
                        </button>
                    }
                </div>
            </div>

            <!-- FOOTER -->
            <div class="card-footer text-center">
                <small class="text-muted">
                    Already have an account?
                    @Html.ActionLink("Sign In", "Login", "Account")
                </small>
            </div>

        </div>
    </div>
</div>

<script>
    (function () {
        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.toggle-password');
            if (!btn) return;
            e.preventDefault();

            var input = document.querySelector(btn.getAttribute('data-target'));
            if (!input) return;

            var isPassword = input.type === 'password';
            input.type = isPassword ? 'text' : 'password';
            btn.textContent = isPassword ? 'Hide' : 'Show';
            btn.setAttribute('aria-label', isPassword ? 'Hide password' : 'Show password');
        });
    })();
</script>

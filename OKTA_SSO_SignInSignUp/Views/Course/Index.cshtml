@model IEnumerable<OKTA_SSO_SignInSignUp.Models.Course>
@{
    ViewBag.Title = "Courses";
}

<section class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">All Courses</h3>

        <!-- (Optional) Add user button -->
        @* @Html.ActionLink("Add User", "Create", "User", null, new { @class = "btn btn-sm btn-primary" }) *@
    </div>

    <!-- Optional: quick search (client-side) -->
    <div class="mb-3">
        <input id="courseSearch" class="form-control" type="text" placeholder="Search by name, username or email..." />
    </div>

    <div class="table-responsive">
        <table id="coursesTable" class="table table-striped table-hover table-bordered">
            <thead class="thead-dark">
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>Totalmarks</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var i = 1;
                    foreach (var u in Model ?? Enumerable.Empty<OKTA_SSO_SignInSignUp.Models.Course>())
                    {
                        <tr>
                            <td>@i</td>
                            <td>@u.Name)</td>
                            <td>@u.Totalmarks</td>
                            <td>@u.CreatedDate</td>
                            <td>
                                @Html.ActionLink("Edit", "Edit", "Course", new { id = u.Id }, new { @class = "btn btn-sm btn-outline-primary mr-1" })
                                @Html.ActionLink("Delete", "Delete", "Course", new { id = u.Id }, new { @class = "btn btn-sm btn-outline-danger" })
                            </td>
                        </tr>
                        i++;
                    }
                }
            </tbody>
        </table>
    </div>
</section>

@section scripts {
    <script>
    // simple client-side filter by text
    (function () {
        var search = document.getElementById('courseSearch');
        var table = document.getElementById('coursesTable').getElementsByTagName('tbody')[0];

        if (!search || !table) return;

        search.addEventListener('input', function () {
            var q = (this.value || '').toLowerCase();
            Array.prototype.forEach.call(table.rows, function (row) {
                var text = row.innerText.toLowerCase();
                row.style.display = text.indexOf(q) > -1 ? '' : 'none';
            });
        });
    })();
    </script>
}
@{
    ViewBag.Title = "My Courses";
}

<section class="container my-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 text-center">
                    <div class="mb-3" aria-hidden="true">
                        <span class="d-inline-flex align-items-center justify-content-center rounded-circle"
                              style="width:64px;height:64px;background:#e9f5ff;color:#0d6efd;">
                            <i class="fa fa-book" aria-hidden="true"></i>
                        </span>
                    </div>
                    <h4 class="mb-2">No courses yet</h4>
                    <p class="text-muted mb-4">
                        You haven’t enrolled in any courses. Explore the catalog to get started.
                    </p>

                    @* Primary action *@
                    @Html.ActionLink("Browse all courses", "Index", "Courses", null, new { @class = "btn btn-primary px-4" })

                    @* Secondary action (optional) *@
                    <div class="mt-2">
                        @Html.ActionLink("View featured courses", "Featured", "Courses", null, new { @class = "btn btn-link" })
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>